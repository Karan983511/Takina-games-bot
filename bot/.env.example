# ─── Required ────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# ─── Optional ────────────────────────────────────────────────
# Set to your guild ID during development to register commands instantly.
# Leave blank for global command registration (takes up to 1 hour).
GUILD_ID=

# Log level: error | warn | info | debug
LOG_LEVEL=info
